def parse_prometheus_labels(raw_labels: str) -> dict[str, str]:
    labels: dict[str, str] = {}
    if not raw_labels:
        return labels

    items: list[str] = []
    current: list[str] = []
    in_quotes = False
    escape = False

    for ch in raw_labels:
        if escape:
            current.append(ch)
            escape = False
            continue
        if ch == "\\":
            current.append(ch)
            escape = True
            continue
        if ch == '"':
            in_quotes = not in_quotes
            current.append(ch)
            continue
        if ch == "," and not in_quotes:
            items.append("".join(current))
            current = []
            continue
        current.append(ch)

    if current:
        items.append("".join(current))

    for item in items:
        if "=" not in item:
            continue
        key, value = item.split("=", 1)
        labels[key] = value.strip().strip('"')

    return labels


def metric_is_relevant(
    labels: dict[str, str], model_aliases: set[str], model_targets: set[str]
) -> bool:
    requested_model = labels.get("requested_model")
    if requested_model and requested_model in model_aliases:
        return True
    model_label = labels.get("model")
    if model_label and model_label in model_targets:
        return True
    return not requested_model and not model_label


def refresh_stats_from_metrics() -> None:
    metrics_url = f"http://localhost:{listen_port}/metrics/"
    model_aliases = {"claude-sonnet-4.6", "claude-haiku-4.5"}
    model_targets = {backend_model, f"azure/{backend_model}"}

    totals = {
        "requests": 0.0,
        "errors": 0.0,
        "prompt_tokens": 0.0,
        "completion_tokens": 0.0,
        "estimated_cost": 0.0,
    }

    try:
        with urllib.request.urlopen(metrics_url, timeout=2) as response:
            payload = response.read().decode("utf-8")
    except (urllib.error.URLError, TimeoutError):
        return

    for line in payload.splitlines():
        if not line or line.startswith("#"):
            continue
        if " " not in line:
            continue
        metric_part, value_str = line.rsplit(" ", 1)
        try:
            value = float(value_str)
        except ValueError:
            continue

        if "{" in metric_part:
            name, label_chunk = metric_part.split("{", 1)
            label_chunk = label_chunk.rstrip("}")
            labels = parse_prometheus_labels(label_chunk)
        else:
            name = metric_part
            labels = {}

        if not metric_is_relevant(labels, model_aliases, model_targets):
            continue

        if name in {
            "litellm_proxy_total_requests_metric",
            "litellm_proxy_total_requests_metric_total",
        }:
            totals["requests"] += value
        elif name in {
            "litellm_proxy_failed_requests_metric",
            "litellm_proxy_failed_requests_metric_total",
        }:
            totals["errors"] += value
        elif name in {
            "litellm_input_tokens_metric",
            "litellm_input_tokens_metric_total",
        }:
            totals["prompt_tokens"] += value
        elif name in {
            "litellm_output_tokens_metric",
            "litellm_output_tokens_metric_total",
        }:
            totals["completion_tokens"] += value
        elif name in {"litellm_spend_metric", "litellm_spend_metric_total"}:
            totals["estimated_cost"] += value

    with stats_lock:
        stats["requests"] = int(totals["requests"])
        stats["errors"] = int(totals["errors"])
        stats["prompt_tokens"] = int(totals["prompt_tokens"])
        stats["completion_tokens"] = int(totals["completion_tokens"])
        stats["estimated_cost"] = float(totals["estimated_cost"])


def metrics_polling_loop() -> None:
    while True:
        refresh_stats_from_metrics()
        time.sleep(1.0)


