# Retention configuration (can be overridden with env vars)
DAILY_RETENTION_DAYS = int(os.environ.get("PERSISTENT_DAILY_RETENTION_DAYS", "90"))
WEEKLY_RETENTION_WEEKS = int(os.environ.get("PERSISTENT_WEEKLY_RETENTION_WEEKS", "52"))
MONTHLY_RETENTION_MONTHS = int(os.environ.get("PERSISTENT_MONTHLY_RETENTION_MONTHS", "36"))

# Persistent aggregated counters structure
# Structure:
# {
#   "all_time": {counters...},
#   "daily": {"YYYY-MM-DD": {counters...}},
#   "weekly": {"YYYY-WWW": {counters...}},
#   "monthly": {"YYYY-MM": {counters...}},
#   "last_updated": ISO8601
# }

def _zero_counters():
    return {
        "requests": 0,
        "errors": 0,
        "prompt_tokens": 0,
        "completion_tokens": 0,
        "reasoning_tokens": 0,
        "estimated_cost": 0.0,
        "last_latency": 0.0,
        "start_time": None,
        "avg_rpm": 0.0,
        "avg_tpm": 0.0,
    }

persistent_lock = threading.Lock()
_persistent_stats: dict | None = None
_persistence_dirty = False


def load_persistent_stats() -> dict:
    global _persistent_stats
    path = Path(PERSISTENT_STATS_FILE)
    if not path.exists():
        _persistent_stats = {
            "all_time": _zero_counters(),
            "daily": {},
            "weekly": {},
            "monthly": {},
            "last_updated": datetime.now(UTC).isoformat(),
        }
        return _persistent_stats

    try:
        with path.open("r", encoding="utf-8") as f:
            data = json.load(f)
    except Exception:
        # If file is corrupted or unreadable, start fresh but keep a backup
        try:
            backup = path.with_suffix(".corrupt")
            path.replace(backup)
        except Exception:
            pass
        _persistent_stats = {
            "all_time": _zero_counters(),
            "daily": {},
            "weekly": {},
            "monthly": {},
            "last_updated": datetime.now(UTC).isoformat(),
        }
        return _persistent_stats

    # Normalize loaded structure
    all_time = data.get("all_time") or _zero_counters()
    daily = data.get("daily") or {}
    weekly = data.get("weekly") or {}
    monthly = data.get("monthly") or {}

    _persistent_stats = {
        "all_time": {**_zero_counters(), **all_time},
        "daily": {k: {**_zero_counters(), **v} for k, v in daily.items()},
        "weekly": {k: {**_zero_counters(), **v} for k, v in weekly.items()},
        "monthly": {k: {**_zero_counters(), **v} for k, v in monthly.items()},
        "last_updated": data.get("last_updated") or datetime.now(UTC).isoformat(),
    }
    return _persistent_stats


def _atomic_write(path: Path, data: dict) -> None:
    tmp = path.with_suffix(".tmp")
    tmp.parent.mkdir(parents=True, exist_ok=True)
    with tmp.open("w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
    try:
        tmp.replace(path)
    except Exception:
        # Fallback to rename
        tmp.rename(path)


def save_persistent_stats(force: bool = False) -> None:
    """Persist aggregated stats to disk (debounced by background thread)."""
    global _persistence_dirty
    with persistent_lock:
        if not force and not _persistence_dirty:
            return
        if _persistent_stats is None:
            return
        try:
            path = Path(PERSISTENT_STATS_FILE)
            _atomic_write(path, _persistent_stats)
            _persistence_dirty = False
        except Exception as e:
            # Best-effort persistence; do not raise.
            console.print(f"[yellow]Warning: failed to persist stats: {e}[/yellow]")


def _prune_old_entries(now: datetime) -> None:
    """Prune old daily/weekly/monthly buckets based on retention policies."""
    if _persistent_stats is None:
        return
    cutoff_daily = (now - timedelta(days=DAILY_RETENTION_DAYS)).date()
    cutoff_week = (now - timedelta(weeks=WEEKLY_RETENTION_WEEKS)).date()
    cutoff_month = now.replace(day=1) - timedelta(days=30 * MONTHLY_RETENTION_MONTHS)

    # Daily
    keys_to_delete = []
    for k in list(_persistent_stats["daily"].keys()):
        try:
            d = datetime.fromisoformat(k).date()
        except Exception:
            # If key not parseable, drop it to keep structure clean
            keys_to_delete.append(k)
            continue
        if d < cutoff_daily:
            keys_to_delete.append(k)
    for k in keys_to_delete:
        _persistent_stats["daily"].pop(k, None)

    # Weekly (keys like YYYY-Www)
    keys_to_delete = []
    for k in list(_persistent_stats["weekly"].keys()):
        try:
            year_str, week_str = k.split("-W")
            year = int(year_str)
            week = int(week_str)
            d = datetime.fromisocalendar(year, week, 1).date()
        except Exception:
            keys_to_delete.append(k)
            continue
        if d < cutoff_week:
            keys_to_delete.append(k)
    for k in keys_to_delete:
        _persistent_stats["weekly"].pop(k, None)

    # Monthly (keys like YYYY-MM)
    keys_to_delete = []
    for k in list(_persistent_stats["monthly"].keys()):
        try:
            year_str, month_str = k.split("-")
            year = int(year_str)
            month = int(month_str)
            d = datetime(year, month, 1).date()
        except Exception:
            keys_to_delete.append(k)
            continue
        if d < cutoff_month.date():
            keys_to_delete.append(k)
    for k in keys_to_delete:
        _persistent_stats["monthly"].pop(k, None)


def _persistence_thread() -> None:
    """Background thread that periodically flushes persistent stats to disk."""
    while True:
        try:
            save_persistent_stats()
        except Exception:
            pass
        time.sleep(5.0)


def update_persistent_stats(
    requests: int = 0,
    errors: int = 0,
    prompt_tokens: int = 0,
    completion_tokens: int = 0,
    reasoning_tokens: int = 0,
    estimated_cost: float = 0.0,
    timestamp: datetime | None = None,
) -> None:
    """Add increments to persistent and rolling aggregates."""
    global _persistence_dirty
    if timestamp is None:
        timestamp = datetime.now(UTC)
    date_key = timestamp.date().isoformat()
    iso = timestamp.isocalendar()
    week_key = f"{iso[0]}-W{iso[1]:02d}"
    month_key = f"{timestamp.year}-{timestamp.month:02d}"

    with persistent_lock:
        if _persistent_stats is None:
            load_persistent_stats()
        # All time
        at = _persistent_stats["all_time"]
        at["requests"] += int(requests)
        at["errors"] += int(errors)
        at["prompt_tokens"] += int(prompt_tokens)
        at["completion_tokens"] += int(completion_tokens)
        at["reasoning_tokens"] += int(reasoning_tokens)
        at["estimated_cost"] += float(estimated_cost)
        # Initialize start_time if missing and compute rolling averages
        if at.get("start_time") is None:
            at["start_time"] = timestamp.isoformat()
        try:
            elapsed_all = (timestamp - datetime.fromisoformat(at["start_time"])) if at.get("start_time") else timedelta(seconds=0)
            minutes_all = max(elapsed_all.total_seconds() / 60, 1/60)
            at["avg_rpm"] = at["requests"] / minutes_all
            total_tokens_all = at["prompt_tokens"] + at["completion_tokens"]
            at["avg_tpm"] = total_tokens_all / minutes_all
        except Exception:
            pass

        # Daily
        day = _persistent_stats["daily"].setdefault(date_key, _zero_counters())
        day["requests"] += int(requests)
        day["errors"] += int(errors)
        day["prompt_tokens"] += int(prompt_tokens)
        day["completion_tokens"] += int(completion_tokens)
        day["reasoning_tokens"] += int(reasoning_tokens)
        day["estimated_cost"] += float(estimated_cost)
        # Update daily averages (RPM/TPM)
        if day.get("start_time") is None:
            day["start_time"] = timestamp.isoformat()
        try:
            elapsed_day = (timestamp - datetime.fromisoformat(day["start_time"])) if day.get("start_time") else timedelta(seconds=0)
            minutes_day = max(elapsed_day.total_seconds() / 60, 1/60)
            day["avg_rpm"] = day["requests"] / minutes_day
            total_tokens_day = day["prompt_tokens"] + day["completion_tokens"]
            day["avg_tpm"] = total_tokens_day / minutes_day
        except Exception:
            pass

        # Weekly
        week = _persistent_stats["weekly"].setdefault(week_key, _zero_counters())
        week["requests"] += int(requests)
        week["errors"] += int(errors)
        week["prompt_tokens"] += int(prompt_tokens)
        week["completion_tokens"] += int(completion_tokens)
        week["reasoning_tokens"] += int(reasoning_tokens)
        week["estimated_cost"] += float(estimated_cost)
        if week.get("start_time") is None:
            week["start_time"] = timestamp.isoformat()
        try:
            elapsed_week = (timestamp - datetime.fromisoformat(week["start_time"])) if week.get("start_time") else timedelta(seconds=0)
            minutes_week = max(elapsed_week.total_seconds() / 60, 1/60)
            week["avg_rpm"] = week["requests"] / minutes_week
            total_tokens_week = week["prompt_tokens"] + week["completion_tokens"]
            week["avg_tpm"] = total_tokens_week / minutes_week
        except Exception:
            pass

        # Monthly
        month = _persistent_stats["monthly"].setdefault(month_key, _zero_counters())
        month["requests"] += int(requests)
        month["errors"] += int(errors)
        month["prompt_tokens"] += int(prompt_tokens)
        month["completion_tokens"] += int(completion_tokens)
        month["reasoning_tokens"] += int(reasoning_tokens)
        month["estimated_cost"] += float(estimated_cost)
        if month.get("start_time") is None:
            month["start_time"] = timestamp.isoformat()
        try:
            elapsed_month = (timestamp - datetime.fromisoformat(month["start_time"])) if month.get("start_time") else timedelta(seconds=0)
            minutes_month = max(elapsed_month.total_seconds() / 60, 1/60)
            month["avg_rpm"] = month["requests"] / minutes_month
            total_tokens_month = month["prompt_tokens"] + month["completion_tokens"]
            month["avg_tpm"] = total_tokens_month / minutes_month
        except Exception:
            pass

        _persistent_stats["last_updated"] = timestamp.isoformat()

        # Prune older buckets (best-effort)
        try:
            _prune_old_entries(timestamp)
        except Exception:
            pass

        _persistence_dirty = True


def update_latency_in_persistent_stats(latency_seconds: float, timestamp: datetime | None = None) -> None:
    """Update last_latency for all time buckets. Call this after each request to track average latency."""
    global _persistence_dirty
    if timestamp is None:
        timestamp = datetime.now(UTC)
    date_key = timestamp.date().isoformat()
    iso = timestamp.isocalendar()
    week_key = f"{iso[0]}-W{iso[1]:02d}"
    month_key = f"{timestamp.year}-{timestamp.month:02d}"

    with persistent_lock:
        if _persistent_stats is None:
            load_persistent_stats()

        # Update last_latency for all time buckets
        if _persistent_stats["all_time"].get("start_time"):
            _persistent_stats["all_time"]["last_latency"] = latency_seconds

        day = _persistent_stats["daily"].get(date_key)
        if day and day.get("start_time"):
            day["last_latency"] = latency_seconds

        week = _persistent_stats["weekly"].get(week_key)
        if week and week.get("start_time"):
            week["last_latency"] = latency_seconds

        month = _persistent_stats["monthly"].get(month_key)
        if month and month.get("start_time"):
            month["last_latency"] = latency_seconds

        _persistence_dirty = True


# Load persistent stats at startup and start background flusher
load_persistent_stats()
threading.Thread(target=_persistence_thread, daemon=True).start()

