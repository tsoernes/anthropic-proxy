def run_proxy():

    config_path = write_proxy_config()

    # Build kwargs so we can attempt to pass uvicorn-related options (access_log/log_level)
    # but fall back if the proxy_cli callback doesn't accept them.
    base_kwargs = dict(
        host="0.0.0.0",
        port=int(listen_port),
        api_base=None,
        api_version=AZURE_API_VERSION,
        model=None,
        alias=None,
        add_key=None,
        headers=None,
        save=False,
        debug=False,
        detailed_debug=False,
        temperature=None,
        max_tokens=None,
        request_timeout=None,
        drop_params=False,
        add_function_to_prompt=False,
        config=config_path,
        max_budget=None,
        telemetry=False,
        test=False,
        local=False,
        num_workers=1,
        test_async=False,
        iam_token_db_auth=False,
        num_requests=10,
        use_queue=False,
        health=False,
        version=False,
        run_gunicorn=False,
        run_hypercorn=False,
        ssl_keyfile_path=None,
        ssl_certfile_path=None,
        ciphers=None,
        log_config=None,
        use_prisma_db_push=False,
        skip_server_startup=False,
        keepalive_timeout=None,
        max_requests_before_restart=None,
    )

    # Common uvicorn options we'd like to set to suppress access logs if supported.
    extra_attempt = {"access_log": False, "log_level": "critical", "log_config": None}

    # Try with the extra uvicorn-specific options first; fall back to base_kwargs on TypeError.
    try:
        proxy_cli.run_server.callback(**{**base_kwargs, **extra_attempt})
        return
    except TypeError:
        try:
            proxy_cli.run_server.callback(**base_kwargs)
            return
        except Exception:
            # If both attempts fail, raise to surface the error
            raise


