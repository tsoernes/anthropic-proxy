# Aggressive logging suppression: monkey-patch StreamHandler.emit to drop access logs
# This catches GET/POST/PUT/DELETE/PATCH/HEAD/OPTIONS access log lines from uvicorn and other ASGI servers.
_original_streamhandler_emit = logging.StreamHandler.emit

def _silenced_emit(self, record):
    msg = record.getMessage() if record else ""
    # Suppress access log patterns like: INFO: 127.0.0.1:port - "METHOD /path HTTP/1.1" status
    if any(x in msg for x in ('"GET ', '"POST ', '"PUT ', '"DELETE ', '"PATCH ', '"HEAD ', '"OPTIONS ')):
        return
    # Also suppress if logger name is a known access logger
    if record.name in ("uvicorn.access", "uvicorn", "gunicorn.access", "hypercorn.access"):
        return
    return _original_streamhandler_emit(self, record)

# Monkey-patch before uvicorn configures its loggers
logging.StreamHandler.emit = _silenced_emit

