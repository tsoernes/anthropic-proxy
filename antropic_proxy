def success_callback(kwargs, response, start_time, end_time):

    # Normalize usage object: litellm/clients sometimes provide usage as a dict,
    # other times as an object with attributes, and reasoning_tokens may be nested
    # inside completion_tokens_details or output_tokens_details. Support all cases.
    usage = {}
    try:
        if hasattr(response, "usage"):
            usage = response.usage or {}
        elif isinstance(response, dict):
            usage = response.get("usage", {}) or {}
        else:
            # Fallback to mapping-style access if available
            get_fn = getattr(response, "get", None)
            if callable(get_fn):
                usage = get_fn("usage", {}) or {}
            else:
                usage = {}
    except Exception:
        usage = {}

    def _get_int(u, key):
        try:
            if isinstance(u, dict):
                return int(u.get(key, 0) or 0)
            return int(getattr(u, key, 0) or 0)
        except Exception:
            return 0

    def _get_reasoning_from_usage(u):
        if u is None:
            return 0
        # Direct top-level key
        if isinstance(u, dict):
            if "reasoning_tokens" in u:
                return int(u.get("reasoning_tokens") or 0)
            # Common nested locations
            for nested_key in (
                "completion_tokens_details",
                "completion_tokens_detail",
                "output_tokens_details",
                "output_tokens_detail",
            ):
                nested = u.get(nested_key)
                if isinstance(nested, dict) and "reasoning_tokens" in nested:
                    return int(nested.get("reasoning_tokens") or 0)
                if nested is not None and hasattr(nested, "reasoning_tokens"):
                    return int(nested.reasoning_tokens or 0)
            return 0
        # Attr-style usage object
        if hasattr(u, "reasoning_tokens"):
            try:
                return int(u.reasoning_tokens or 0)
            except Exception:
                return 0
        for attr in ("completion_tokens_details", "output_tokens_details"):
            nested = getattr(u, attr, None)
            if nested is None:
                continue
            if isinstance(nested, dict) and "reasoning_tokens" in nested:
                return int(nested.get("reasoning_tokens") or 0)
            if hasattr(nested, "reasoning_tokens"):
                try:
                    return int(nested.reasoning_tokens or 0)
                except Exception:
                    return 0
        return 0

    prompt_tokens = _get_int(usage, "prompt_tokens")
    completion_tokens = _get_int(usage, "completion_tokens")
    reasoning_tokens = _get_reasoning_from_usage(usage)

    # Calculate latency for this request
    latency = end_time - start_time
    now = time.time()
    total_tokens = prompt_tokens + completion_tokens

    # Update runtime counters under lock so dashboard sees latencies reliably
    with stats_lock:
        stats["requests"] += 1
        stats["prompt_tokens"] += prompt_tokens
        stats["completion_tokens"] += completion_tokens
        stats["reasoning_tokens"] += reasoning_tokens
        stats["latencies"].append(latency)
        stats["request_times"].append((now, total_tokens))

    # Update latency in persistent stats for all time buckets
    try:
        update_latency_in_persistent_stats(latency, timestamp=datetime.now(UTC))
    except Exception:
        pass

    # Record cost/usage in a toolkit-compatible way. azure-llm-toolkit's
    # InMemoryCostTracker exposes record_cost(...) not add_usage, so support
    # both APIs for compatibility with other cost tracker implementations.
    amount = 0.0
    try:
        # Compute estimated amount using a regex-aware estimator that supports gpt-5.x variants.
        try:
            amount = estimate_amount_for_model(
                model_name=backend_model,
                tokens_input=prompt_tokens,
                tokens_output=completion_tokens,
                tokens_cached_input=0,
            )
        except Exception:
            amount = 0.0

        if hasattr(cost_tracker, "add_usage"):
            # Some cost tracker implementations provide add_usage(model, prompt_tokens, completion_tokens)
            try:
                cost_tracker.add_usage(
                    model=backend_model,
                    prompt_tokens=prompt_tokens,
                    completion_tokens=completion_tokens,
                )
            except Exception:
                pass
        elif hasattr(cost_tracker, "record_cost"):
            # Map to record_cost(category, model, tokens_input, tokens_output, tokens_cached_input, currency, amount, metadata)
            try:
                cost_tracker.record_cost(
                    category="chat",
                    model=backend_model,
                    tokens_input=prompt_tokens,
                    tokens_output=completion_tokens,
                    tokens_cached_input=0,
                    currency=getattr(cost_tracker, "currency", "usd"),
                    amount=amount,
                    metadata={"reasoning_tokens": reasoning_tokens},
                )
            except TypeError:
                # Older record_cost signatures may differ; try positional fallback
                try:
                    cost_tracker.record_cost(
                        "chat",
                        backend_model,
                        prompt_tokens,
                        completion_tokens,
                        0,
                        getattr(cost_tracker, "currency", "usd"),
                        amount,
                        {"reasoning_tokens": reasoning_tokens},
                    )
                except Exception:
                    # Best-effort: ignore cost tracking failure
                    pass
    except Exception:
        # Do not let cost tracking break the proxy
        pass

    # Also update persistent aggregates (best-effort)
    try:
        update_persistent_stats(
            requests=1,
            errors=0,
            prompt_tokens=prompt_tokens,
            completion_tokens=completion_tokens,
            reasoning_tokens=reasoning_tokens,
            estimated_cost=amount,
            timestamp=datetime.now(UTC),
        )
    except Exception:
        pass

    # Log request/response if debug logging is enabled
    try:
        log_request_response(
            request_data={
                "model": backend_model,
                "timestamp": now,
                "tokens_in": prompt_tokens,
                "tokens_out": completion_tokens,
                "reasoning_tokens": reasoning_tokens,
            },
            response_data={
                "latency": latency,
                "estimated_cost": amount,
                "usage": dict(usage) if isinstance(usage, dict) else {},
            },
        )
    except Exception:
        pass


def failure_callback(kwargs, error, start_time, end_time):
    stats["errors"] += 1

    # Log failed request if debug logging is enabled
    try:
        log_request_response(
            request_data={
                "model": backend_model,
                "timestamp": time.time(),
            },
            response_data=None,
            error=error,
        )
    except Exception:
        pass


litellm.success_callback = [success_callback]
litellm.failure_callback = [failure_callback]


