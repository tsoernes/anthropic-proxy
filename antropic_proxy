def _resolve_pricing_for_model(model_name: str):
    """Return pricing dict (input/output/cached_input) for model_name using regex patterns.
    Returns None if no match found.
    """
    if not model_name:
        return None
    for pat, pricing in MODEL_PRICING_PATTERNS:
        try:
            if pat.match(model_name):
                return pricing
        except Exception:
            continue
    return None


def estimate_amount_for_model(model_name: str, tokens_input: int, tokens_output: int, tokens_cached_input: int = 0) -> float:
    """Estimate amount (currency units) for the given token counts.

    First try the CostEstimator (which may have exact-name registrations). If that
    yields no usable result, fall back to regex-based pricing using
    MODEL_PRICING_PATTERNS.
    """
    # Try toolkit estimator first (best-effort)
    try:
        amt = cost_estimator.estimate_cost(
            model=model_name,
            tokens_input=tokens_input,
            tokens_output=tokens_output,
            tokens_cached_input=tokens_cached_input,
        )
        # If estimator returned a non-zero amount, use it
        if amt:
            return float(amt)
    except Exception:
        pass

    # Fallback: resolve pricing via regex patterns and compute manually
    pricing = _resolve_pricing_for_model(model_name)
    if not pricing:
        return 0.0
    input_price = pricing.get("input", 0.0)
    output_price = pricing.get("output", 0.0)
    cached_input_price = pricing.get("cached_input", 0.0)
    # Prices are per 1M tokens
    amt = (tokens_input * input_price + tokens_output * output_price + tokens_cached_input * cached_input_price) / 1_000_000.0
    return float(amt)

