import re

# MODEL_PRICING_PATTERNS: tuples of (compiled_regex, pricing_dict). Patterns are
# matched case-insensitively. Prices are expressed per 1M tokens.
MODEL_PRICING_PATTERNS = [
    (re.compile(r"^Kimi-?K?2\.5$", re.I), {"input": 0.60, "output": 3.00, "cached_input": 0.0}),
    # gpt-5 variants: gpt-5, gpt-5.1, gpt-5.2, etc. Support optional suffixes like -codex and -codex-mini
    (re.compile(r"^gpt-5(?:\.\d+)?-codex-mini$", re.I), {"input": 0.25, "output": 2.0, "cached_input": 0.03}),
    (re.compile(r"^gpt-5(?:\.\d+)?-codex$", re.I), {"input": 1.25, "output": 10.0, "cached_input": 0.13}),
    (re.compile(r"^gpt-5(?:\.\d+)?$", re.I), {"input": 1.25, "output": 10.0, "cached_input": 0.13}),
]

