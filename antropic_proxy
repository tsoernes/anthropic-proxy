_debug_logger: logging.Logger | None = None


def _init_debug_logger() -> logging.Logger | None:
    """Initialize a debug logger that writes sanitized request logs to a file.

    Set PROXY_DEBUG_LOG environment variable to the log file path.
    Logs are rotated daily.
    """
    global _debug_logger
    log_path = os.environ.get("PROXY_DEBUG_LOG", "")
    if not log_path or _debug_logger is not None:
        return _debug_logger

    try:
        from logging.handlers import RotatingFileHandler

        logger = logging.getLogger("proxy_debug")
        logger.setLevel(logging.DEBUG)
        logger.propagate = False

        # Clear any existing handlers
        try:
            logger.handlers.clear()
        except Exception:
            for h in list(logger.handlers):
                try:
                    logger.removeHandler(h)
                except Exception:
                    pass

        handler = RotatingFileHandler(
            log_path,
            maxBytes=10 * 1024 * 1024,  # 10MB
            backupCount=5,
            encoding="utf-8",
        )
        handler.setLevel(logging.DEBUG)
        formatter = logging.Formatter(
            "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
        )
        handler.setFormatter(formatter)
        logger.addHandler(handler)

        _debug_logger = logger
        return logger
    except Exception:
        return None


def _sanitize_for_log(data: dict) -> dict:
    """Remove sensitive fields from request/response data for logging."""
    if not isinstance(data, dict):
        return {}
    # Deep copy to avoid modifying original
    import copy

    sanitized = copy.deepcopy(data)

    # Remove common sensitive fields
    sensitive_keys = {"api_key", "authorization", "x-api-key", "token", "password", "secret"}

    def _redact(obj):
        if isinstance(obj, dict):
            for k in list(obj.keys()):
                if isinstance(k, str) and any(s in k.lower() for s in sensitive_keys):
                    obj[k] = "[REDACTED]"
                else:
                    obj[k] = _redact(obj[k])
        elif isinstance(obj, list):
            for i, item in enumerate(obj):
                obj[i] = _redact(item)
        return obj

    return _redact(sanitized)


def log_request_response(request_data: dict, response_data: dict | None, error: Exception | None = None):
    """Log a sanitized request/response pair if debug logging is enabled."""
    logger = _init_debug_logger()
    if logger is None:
        return

    try:
        entry = {
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "request": _sanitize_for_log(request_data),
        }
        if error:
            entry["error"] = str(error)
        elif response_data:
            entry["response"] = _sanitize_for_log(response_data)

        logger.debug(f"Request: {entry}")
    except Exception:
        pass


# ------------------------------------------------
# Graceful shutdown
# ------------------------------------------------

_shutting_down = threading.Event()


def _signal_handler(signum: int, frame) -> None:
    """Handle SIGINT/SIGTERM by saving stats and setting shutdown flag."""
    if _shutting_down.is_set():
        # Force exit on second signal
        sys.exit(1)
    _shutting_down.set()
    print(f"\nReceived signal {signum}, shutting down gracefully...")
    try:
        save_persistent_stats(force=True)
        print("Stats saved.")
    except Exception as e:
        print(f"Error saving stats: {e}")
    sys.exit(0)


def _register_signal_handlers():
    """Register signal handlers for graceful shutdown."""
    try:
        signal.signal(signal.SIGINT, _signal_handler)
        signal.signal(signal.SIGTERM, _signal_handler)
    except (ValueError, AttributeError):
        # May fail on Windows or if signals already set
        pass


def _atexit_handler():
    """Last-resort save on exit."""
    try:
        save_persistent_stats(force=True)
    except Exception:
        pass


atexit.register(_atexit_handler)

