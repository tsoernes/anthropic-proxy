def dashboard():

    elapsed = time.time() - start_time

    with stats_lock:
        requests = stats["requests"]
        errors = stats["errors"]
        prompt_tokens = stats["prompt_tokens"]
        completion_tokens = stats["completion_tokens"]
        reasoning_tokens = stats["reasoning_tokens"]
        estimated_cost = stats["estimated_cost"]
        latencies = list(stats["latencies"])

    # Capture a recent latency to surface even when latencies deque is empty
    recent_latency = None
    try:
        with persistent_lock:
            if _persistent_stats is None:
                load_persistent_stats()
            # last_latency is stored on all_time for best-effort display
            recent_latency = (_persistent_stats or {}).get("all_time", {}).get("last_latency")
    except Exception:
        recent_latency = None

    # Load persistent summaries for display (best-effort)
    persistent_summary = {}
    try:
        with persistent_lock:
            persistent_summary = _persistent_stats or {}
    except Exception:
        persistent_summary = {}

    # Extract human-friendly totals
    all_time = persistent_summary.get("all_time", {})
    daily = persistent_summary.get("daily", {})
    weekly = persistent_summary.get("weekly", {})
    monthly = persistent_summary.get("monthly", {})

    today_key = datetime.now(UTC).date().isoformat()
    week_iso = datetime.now(UTC).isocalendar()
    this_week_key = f"{week_iso[0]}-W{week_iso[1]:02d}"
    this_month_key = f"{datetime.now(UTC).year}-{datetime.now(UTC).month:02d}"

    today = daily.get(today_key, _zero_counters())
    this_week = weekly.get(this_week_key, _zero_counters())
    this_month = monthly.get(this_month_key, _zero_counters())
    all_time_total = all_time or _zero_counters()

    rpm = requests / (elapsed / 60) if elapsed else 0

    total_tokens = prompt_tokens + completion_tokens
    tpm = total_tokens / (elapsed / 60) if elapsed else 0

    if latencies:
        avg_latency = sum(latencies) / len(latencies)
        avg_latency_display = f"{avg_latency * 1000:.1f} ms"
    else:
        # Fall back to last recorded latency from persistent stats if present
        recent_latency = None
        try:
            with persistent_lock:
                if _persistent_stats is None:
                    load_persistent_stats()
                recent_latency = (_persistent_stats or {}).get("all_time", {}).get("last_latency")
        except Exception:
            recent_latency = None
        if recent_latency and recent_latency > 0:
            avg_latency_display = f"{recent_latency * 1000:.1f} ms (last)"
        else:
            avg_latency_display = "n/a"

    # Update last_latency in persistent all_time for next-run visibility
    try:
        with persistent_lock:
            if _persistent_stats is None:
                load_persistent_stats()
            _persistent_stats["all_time"]["last_latency"] = avg_latency if latencies else (recent_latency or 0.0)
            _persistence_dirty = True
    except Exception:
        pass

    if estimated_cost:
        total_cost = estimated_cost
    else:
        cost_summary = cost_tracker.get_summary()
        if isinstance(cost_summary, dict):
            total_cost = cost_summary.get("total_cost", 0.0)
        else:
            total_cost = cost_summary.total_cost

    table = Table(title="LiteLLM → Azure Proxy Stats")

    # Columns: Metric | Session | Today | This week | This month | All time
    table.add_column("Metric")
    table.add_column("Session", justify="right")
    table.add_column("Today", justify="right")
    table.add_column("This week", justify="right")
    table.add_column("This month", justify="right")
    table.add_column("All time", justify="right")

    # Session-level cost (from in-memory cost tracker)
    try:
        session_cost = cost_tracker.get_total_cost() if hasattr(cost_tracker, "get_total_cost") else 0.0
    except Exception:
        session_cost = 0.0

    today_cost = today.get("estimated_cost", 0.0)
    week_cost = this_week.get("estimated_cost", 0.0)
    month_cost = this_month.get("estimated_cost", 0.0)
    all_time_cost = all_time_total.get("estimated_cost", 0.0)

    # Session avg latency (numeric) and display
    if latencies:
        session_avg = sum(latencies) / len(latencies)
        session_avg_display = f"{session_avg * 1000:.1f} ms"
    else:
        session_avg = None
        # recent_latency may have been loaded earlier from persistent stats
        session_avg_display = avg_latency_display

    all_time_latency = all_time_total.get("last_latency", 0.0)
    all_time_latency_display = f"{all_time_latency * 1000:.1f} ms" if all_time_latency else "n/a"

    # Header row for backend model
    table.add_row("Backend model", backend_model, "", "", "", "")

    # Core metrics rows
    table.add_row(
        "Requests",
        str(requests),
        str(today.get("requests", 0)),
        str(this_week.get("requests", 0)),
        str(this_month.get("requests", 0)),
        str(all_time_total.get("requests", 0)),
    )

    table.add_row(
        "Prompt tokens",
        f"{prompt_tokens:,}",
        f"{today.get('prompt_tokens', 0):,}",
        f"{this_week.get('prompt_tokens', 0):,}",
        f"{this_month.get('prompt_tokens', 0):,}",
        f"{all_time_total.get('prompt_tokens', 0):,}",
    )

    table.add_row(
        "Completion tokens",
        f"{completion_tokens:,}",
        f"{today.get('completion_tokens', 0):,}",
        f"{this_week.get('completion_tokens', 0):,}",
        f"{this_month.get('completion_tokens', 0):,}",
        f"{all_time_total.get('completion_tokens', 0):,}",
    )

    table.add_row(
        "Reasoning tokens",
        f"{reasoning_tokens:,}",
        f"{today.get('reasoning_tokens', 0):,}",
        f"{this_week.get('reasoning_tokens', 0):,}",
        f"{this_month.get('reasoning_tokens', 0):,}",
        f"{all_time_total.get('reasoning_tokens', 0):,}",
    )

    # Average RPM for each time period (stored in persistent stats)
    session_avg_rpm = rpm  # calculated from current session
    today_avg_rpm = today.get("avg_rpm", 0.0)
    week_avg_rpm = this_week.get("avg_rpm", 0.0)
    month_avg_rpm = this_month.get("avg_rpm", 0.0)
    all_time_avg_rpm = all_time_total.get("avg_rpm", 0.0)

    table.add_row(
        "Avg RPM",
        f"{session_avg_rpm:.2f}",
        f"{today_avg_rpm:.2f}",
        f"{week_avg_rpm:.2f}",
        f"{month_avg_rpm:.2f}",
        f"{all_time_avg_rpm:.2f}",
    )

    # Average TPM for each time period (stored in persistent stats)
    session_avg_tpm = tpm  # calculated from current session
    today_avg_tpm = today.get("avg_tpm", 0.0)
    week_avg_tpm = this_week.get("avg_tpm", 0.0)
    month_avg_tpm = this_month.get("avg_tpm", 0.0)
    all_time_avg_tpm = all_time_total.get("avg_tpm", 0.0)

    table.add_row(
        "Avg TPM",
        f"{session_avg_tpm:.2f}",
        f"{today_avg_tpm:.2f}",
        f"{week_avg_tpm:.2f}",
        f"{month_avg_tpm:.2f}",
        f"{all_time_avg_tpm:.2f}",
    )

    # Calculate last-minute RPM and TPM from request_times
    now = time.time()
    one_minute_ago = now - 60
    with stats_lock:
        request_times = list(stats["request_times"])

    last_minute_requests = sum(1 for t, _ in request_times if t >= one_minute_ago)
    last_minute_tokens = sum(tokens for t, tokens in request_times if t >= one_minute_ago)
    # Since we're looking at exactly 1 minute window, RPM = count, TPM = token count
    last_minute_rpm = last_minute_requests
    last_minute_tpm = last_minute_tokens

    table.add_row(
        "RPM (last minute)",
        f"{last_minute_rpm:.0f}",
        "", "", "", "",
    )

    table.add_row(
        "TPM (last minute)",
        f"{last_minute_tpm:.0f}",
        "", "", "", "",
    )

    # Average latency for each time period
    today_avg_latency = today.get("last_latency", 0.0)
    week_avg_latency = this_week.get("last_latency", 0.0)
    month_avg_latency = this_month.get("last_latency", 0.0)
    all_time_avg_latency = all_time_total.get("last_latency", 0.0)

    today_latency_display = f"{today_avg_latency * 1000:.1f} ms" if today_avg_latency else "n/a"
    week_latency_display = f"{week_avg_latency * 1000:.1f} ms" if week_avg_latency else "n/a"
    month_latency_display = f"{month_avg_latency * 1000:.1f} ms" if month_avg_latency else "n/a"
    all_time_latency_display = f"{all_time_avg_latency * 1000:.1f} ms" if all_time_avg_latency else "n/a"

    table.add_row(
        "Avg latency",
        session_avg_display,
        today_latency_display,
        week_latency_display,
        month_latency_display,
        all_time_latency_display,
    )

    table.add_row(
        "Estimated cost",
        f"${session_cost:.4f}",
        f"${today_cost:.4f}",
        f"${week_cost:.4f}",
        f"${month_cost:.4f}",
        f"${all_time_cost:.4f}",
    )

    return Panel(table)


def dashboard_loop():
    try:
        with Live(dashboard(), refresh_per_second=4, console=console) as live:
            while True:
                time.sleep(0.5)
                try:
                    live.update(dashboard())
                except Exception as e:
                    # Log error but keep dashboard running
                    print(f"Dashboard update error: {e}")
                    time.sleep(1.0)
    except Exception as e:
        print(f"Fatal dashboard error: {e}")
        # Keep main thread alive even if dashboard crashes
        while True:
            time.sleep(60)


